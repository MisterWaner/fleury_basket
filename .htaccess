RewriteEngine On

# Si le fichier ou le dossier demandé existe réellement, on le laisse passer normalement (pour le CSS, JS, images)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Sinon, on envoie absolument tout le reste à l'index principal
RewriteRule ^ public/index.php [L]